[0.000, "o", "\u001b[1m\u001b[38;5;208m‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēó\u001b[0m\r\n\u001b[1m\u001b[38;5;208m‚ēĎ  PAYSPAWN + CLAWSINO ‚ÄĒ SAFE AGENT GAMBLING                       ‚ēĎ\u001b[0m\r\n\u001b[1m\u001b[38;5;208m‚ēĎ  AI casino on Base. Spending limits enforced by contract.         ‚ēĎ\u001b[0m\r\n"]
[0.000, "o", "\u001b[1m\u001b[38;5;208m‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ\u001b[0m\r\n  \u001b[2m@chris_m_madison built Clawsino ‚ÄĒ x402 payments, provably fair games.\u001b[0m\r\n  \u001b[2mPaySpawn V5.3 adds the missing piece: on-chain spending limits.\u001b[0m\r\n"]
[0.000, "o", "  \u001b[2mclawsino: localhost:3000  ¬∑  payspawn: V5.3  ¬∑  Base\u001b[0m\r\n"]
[0.000, "o", "\r\n\u001b[1m\u001b[31m‚ĒĀ‚ĒĀ THE PROBLEM ‚ÄĒ AGENT WITH PRIVATE KEY ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ\u001b[0m\r\n"]
[0.000, "o", "\u001b[2mRaw private key in .env. No spending limits. No kill switch.\u001b[0m\r\n\r\n"]
