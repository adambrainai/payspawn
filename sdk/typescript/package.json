{
  "name": "@payspawn/sdk",
  "version": "5.3.1",
  "description": "Financial infrastructure for AI agents. Wallet delegation, x402 payments, on-chain spending limits, agent-to-agent payments with signed receipts. V5.3 on Base.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "payspawn",
    "ai",
    "agent",
    "payments",
    "usdc",
    "base",
    "x402",
    "crypto",
    "web3"
  ],
  "author": "PaySpawn",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/adambrainai/payspawn"
  },
  "homepage": "https://payspawn.ai",
  "bugs": {
    "url": "https://github.com/adambrainai/payspawn/issues"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
