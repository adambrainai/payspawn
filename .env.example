# PaySpawn Environment Variables
# Copy to .env.local and fill in values

# ─── Contracts ────────────────────────────────────────────────────────────────
# V4 (deployed, do not change)
PAYSPAWN_SPENDER_V4=0x71FF87e48b3A66549FbC6A30214b11C4b4975bda

# V5 (set after deploying PaySpawnSpenderV5)
PAYSPAWN_SPENDER_V5=

# Budget Pool Factory (deployed)
BUDGET_POOL_FACTORY_ADDRESS=0xd4bb25e6bf99f450eb9b7b41f7e158c5a5e42305

# ─── Relayer ──────────────────────────────────────────────────────────────────
# Private key for the PaySpawn relayer wallet (executes on-chain payments)
# Relayer address: 0xd983B335e8590e31b460e25c4530219fE085Fa76
RELAYER_PRIVATE_KEY=

# ─── RPC ──────────────────────────────────────────────────────────────────────
# Alchemy Base mainnet RPC URL (recommended) or any Base RPC
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ─── Receipt Signing ──────────────────────────────────────────────────────────
# Secret key for HMAC-SHA256 signing of payment receipts (agent-to-agent verification)
# Generate with: openssl rand -hex 32
RECEIPT_SIGNING_KEY=

# ─── External APIs ────────────────────────────────────────────────────────────
# Coinbase CDP API Key (for Smart Wallet credential generation)
COINBASE_CDP_API_KEY=

# Basescan API Key (for contract verification in deploy scripts)
BASESCAN_API_KEY=9R22J116ZTD5DF912DCBWUWUA2IG9D9TCN
